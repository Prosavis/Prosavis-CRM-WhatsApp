# Firebase (origen) — NO commitear el JSON de service account
FIREBASE_PROJECT_ID=prosavis
GOOGLE_APPLICATION_CREDENTIALS=./secrets/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=prosavis.firebasestorage.app

# Supabase (destino) — service role solo para scripts ETL
SUPABASE_URL=https://djzwjaegxbhlefanmmee.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Opcional: directorio de salida para reportes JSON
MIGRATION_OUTPUT_DIR=./output

# Comandos storage:
#   npm run migrate:storage -- --prefix=whatsapp-media/
#   npm run migrate:storage -- --prefix=whatsapp-media/ --full-prefix

# Opcional: contraseña inicial al provisionar admins (npm run migrate:sync-admins)
# Si no se define, se genera una temporal en consola.
# ADMIN_SYNC_DEFAULT_PASSWORD=
