# Copiar a .env.secrets.local (gitignored) y completar valores.
# Usar con: supabase secrets set --env-file .env.secrets.local

# ─── Google Gemini — Único proveedor de IA del CRM WhatsApp ──────────────
# Gemini 3.5 Flash es el modelo recomendado (GA, mayo 2026):
#   https://ai.google.dev/gemini-api/docs/models/gemini-3.5-flash
GEMINI_API_KEY=
GEMINI_MODEL_REPLY=gemini-3.5-flash
GEMINI_MODEL_JSON=gemini-3.5-flash
GEMINI_MODEL_TRANSCRIBE=gemini-3.5-flash

# ─── WhatsApp / Meta ─────────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=1035566289641219
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
ENABLE_META_SEND=true
WHATSAPP_WEBHOOK_MODE=active
META_GRAPH_API_VERSION=v21.0
