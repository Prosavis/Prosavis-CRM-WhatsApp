# Variables publicas del frontend. Se pueden exponer al navegador.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-local-or-remote-publishable-key
VITE_WHATSAPP_PHONE_NUMBER_ID=

# Secrets privados de Edge Functions. Configurar con `supabase secrets set`
# o desde el Dashboard; nunca exponerlos como variables VITE_*.
ENABLE_META_SEND=false
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_MODE=shadow
META_GRAPH_API_VERSION=v21.0
